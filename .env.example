# ============================================================
# Codex2API Docker 环境变量配置
# 复制此文件为 .env 并修改对应值
# ============================================================

# HTTP 服务端口
CODEX_PORT=8080

# 管理后台登录密钥（可选，设置后首次访问 /admin 会弹出密码输入框）
# ADMIN_SECRET=your-admin-password

# 下游 API 密钥鉴权（逗号分隔，留空则不鉴权）
# CODEX_API_KEYS=sk-your-key-1,sk-your-key-2

# 全局代理（可选）
# CODEX_PROXY_URL=http://host.docker.internal:7890

# WebSocket 传输（可选，设置为 true 启用 WebSocket 连接 Codex 上游）
# USE_WEBSOCKET=true

# 快速调度器（可选，也可在管理后台运行时开启）
# FAST_SCHEDULER_ENABLED=true

# ---- PostgreSQL ----
DATABASE_DRIVER=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=codex2api
DATABASE_PASSWORD=codex2api
DATABASE_NAME=codex2api

# ---- Redis ----
CACHE_DRIVER=redis
# 支持 host:port、redis://...、rediss://...；Aiven / Upstash 通常使用 rediss://
REDIS_ADDR=redis:6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_INSECURE_SKIP_VERIFY=false

# ---- 时区 ----
TZ=Asia/Shanghai
